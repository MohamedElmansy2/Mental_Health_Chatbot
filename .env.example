# ── Copy this file to .env and fill in your values ───────────────────────────
# cp .env.example .env

# Groq API key — https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# Qdrant Cloud — https://cloud.qdrant.io → your cluster
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Hugging Face — your pushed emotion model (Module 2)
# Format: your-hf-username/emotion-roberta
EMOTION_MODEL_ID=your_hf_username/emotion-roberta

# Path to the trained language detection model (Module 1)
# Keep as-is if you follow the folder structure in README
LANG_MODEL_PATH=models/language_detection_tfidf_linearsvc.pkl
